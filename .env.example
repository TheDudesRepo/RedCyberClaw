# RedCyberClaw Environment Configuration
# Copy to .env and fill in your keys

# === AI Providers ===
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx
GOOGLE_API_KEY=xxx

# === Reconnaissance APIs ===
SHODAN_API_KEY=xxx
CENSYS_API_ID=xxx
CENSYS_API_SECRET=xxx
SECURITYTRAILS_API_KEY=xxx

# === Enrichment APIs ===
VIRUSTOTAL_API_KEY=xxx
HUNTER_API_KEY=xxx

# === Search ===
BRAVE_API_KEY=xxx

# === Operational Security ===
DISABLE_TELEMETRY=1
DO_NOT_TRACK=1
CLAUDE_TELEMETRY_DISABLED=1
